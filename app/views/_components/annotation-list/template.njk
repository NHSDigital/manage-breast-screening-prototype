{# app/views/_components/annotation-list/template.njk #}
{% from 'button/macro.njk' import button %}
{#
  Displays a numbered list of annotations with blue badges.

  Params:
    annotations    — array of annotation objects (required)
    startNumber    — number to start counting from (default: 1)
    interactive    — boolean, show bordered cards with hover effects (default: false)
    editable       — boolean, show edit/delete links (default: false)
    editHrefPrefix — URL prefix for edit links, annotation id appended (e.g. "./annotation/edit/")
    addHref        — URL for "Add annotation" button (optional, only shown if editable)
    addAttributes  — additional attributes for the add button (e.g. data-load-modal-url)
    useModals      — boolean, add data-load-modal-url to edit links and add button (default: false)
    emptyText      — text shown when no annotations (default: "If abnormal, add an annotation (concern level 3 or higher)")
    classes        — additional CSS classes on the wrapper
    id             — id attribute on the wrapper element
#}

{% set _annotations = params.annotations | default([]) %}
{% set _startNumber = params.startNumber | default(1) %}
{% set _interactive = params.interactive | default(false) %}
{% set _editable = params.editable | default(false) %}
{% set _useModals = params.useModals | default(false) %}
{% set _emptyText = params.emptyText | default("If abnormal, add an annotation (concern level 3 or higher)") %}

<div class="app-annotation-list{{ ' app-annotation-list--interactive' if _interactive }}{{ ' ' + params.classes if params.classes }}"{{ ' id="' + params.id + '"' if params.id }}>

  {% if _annotations | length == 0 %}
    <p class="app-annotation-list__empty">{{ _emptyText }}</p>
  {% endif %}

  {% if _annotations | length > 0 %}
  <ol class="app-annotation-list__items">
    {% for annotation in _annotations %}
      {% set _number = _startNumber + loop.index0 %}
      {# Handle abnormalityTypes as either a string (from select) or array (from checkboxes) #}
      {% if annotation.abnormalityTypes is string %}
        {% set _typeLabel = annotation.abnormalityTypes if annotation.abnormalityTypes else "Type not set" %}
      {% elseif annotation.abnormalityTypes | length %}
        {# Replace "Other" with "Other: details" when otherDetails is provided #}
        {% set _typeItems = [] %}
        {% for type in annotation.abnormalityTypes %}
          {% if type == "Other" and annotation.otherDetails %}
            {% set _typeItems = _typeItems | push("Other: " + annotation.otherDetails) %}
          {% else %}
            {% set _typeItems = _typeItems | push(type) %}
          {% endif %}
        {% endfor %}
        {% set _typeLabel = _typeItems | join(", ") %}
      {% else %}
        {% set _typeLabel = "Type not set" %}
      {% endif %}
      {% set _concernLabel = annotation.levelOfConcern | formatLevelOfConcern if annotation.levelOfConcern %}

      <li class="app-annotation-list__item" value="{{ _number }}">
        <div class="app-annotation-list__header">
          <span class="app-annotation-list__number">{{ _number }}</span>
          <div class="app-annotation-list__body">
            <span class="app-annotation-list__type">{{ _typeLabel }}</span>

            {% if _concernLabel %}
              <p class="app-annotation-list__meta">{{ _concernLabel }}</p>
            {% endif %}

            {% if annotation.location %}
              <p class="app-annotation-list__meta">Location: {{ annotation.location }}</p>
            {% endif %}

            {% if annotation.comment %}
              <p class="app-annotation-list__meta">Comment: {{ annotation.comment }}</p>
            {% endif %}

            {% if _editable and params.editHrefPrefix %}
              <div class="app-annotation-list__actions">
                <a href="{{ params.editHrefPrefix }}{{ annotation.id }}"
                   class="nhsuk-link nhsuk-link--no-visited-state"
                   {% if _useModals %}data-load-modal-url="{{ params.editHrefPrefix }}{{ annotation.id }}"{% endif %}>
                  Change<span class="nhsuk-u-visually-hidden"> annotation {{ _number }}</span>
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </li>
    {% endfor %}
  </ol>
  {% endif %}

  {% if _editable and params.addHref %}
    {% set _addButtonAttributes = {} %}
    {% if _useModals %}
      {% set _addButtonAttributes = { "data-load-modal-url": params.addHref } %}
    {% endif %}

    {{ button({
      text: "Add another annotation" if _annotations | length > 0 else "Add annotation",
      classes: "nhsuk-button--secondary nhsuk-button--small nhsuk-u-margin-bottom-0",
      href: params.addHref,
      attributes: _addButtonAttributes
    }) }}
  {% endif %}

</div>
