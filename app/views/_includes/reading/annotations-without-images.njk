{# app/views/_includes/reading/annotations-without-images.njk #}
{# Mode: without-images
   Simple annotation lists in two columns inside a card.
   Add/edit opens the annotation page (or modal) with a text location field. #}

{% from '_components/annotation-list/macro.njk' import appAnnotationList %}

{% set annotationsSectionHtml %}
  <div class="nhsuk-grid-row">
    {% for breastSide in ["right", "left"] %}
      {% set Side = breastSide | capitalize %}
      {% set sideAnnotations = rightAnnotations if breastSide == "right" else leftAnnotations %}

      <div class="nhsuk-grid-column-one-half">
        <h3 class="nhsuk-heading-s">{{ Side }} breast</h3>

        {{ appAnnotationList({
          annotations: sideAnnotations,
          editable: true,
          editHrefPrefix: "./annotation/edit/",
          addHref: "./annotation/add?side=" + breastSide,
          useModals: data.settings.modalForms == 'true'
        }) }}

        <span hidden data-annotation-count="{{ breastSide }}" data-count="{{ sideAnnotations | length }}"></span>
      </div>
    {% endfor %}
  </div>
{% endset %}

<div class="nhsuk-grid-row">
  <div class="nhsuk-grid-column-full">
    {{ card({
      heading: "Annotations",
      headingLevel: "2",
      feature: true,
      classes: "nhsuk-u-margin-top-4",
      descriptionHtml: annotationsSectionHtml
    }) }}
  </div>
</div>
