{# app/views/_includes/reading/annotation-form.njk #}
{#
  Reusable form fields for recording an image reading annotation/finding.
  Reads from data.imageReadingTemp.annotationTemp by default.
  Used by annotation.html and the inline form on recall-for-assessment-details.html.

  Optional parent-scope overrides:
    annotationData       — object to read values from (defaults to imageReadingTemp.annotationTemp)
    annotationNamePrefix — string prefix for form field names (defaults to "imageReadingTemp[annotationTemp]")
    annotationIdPrefix   — string prefix for element ids, e.g. "right" (defaults to "")
#}

{% from '_components/collapsible-input/macro.njk' import appCollapsibleInput %}
{% from '_components/option-picker/macro.njk' import appOptionPicker %}

{# Resolve data source and name/id prefixes.
   If annotationNamePrefix is provided by the calling template, we're in parameterised mode:
   use annotationData as the data source and annotationNamePrefix for field names.
   Otherwise fall back to the standard imageReadingTemp.annotationTemp path. #}
{% if annotationNamePrefix is defined and annotationNamePrefix %}
  {% set annotationTemp = annotationData %}
  {% set _namePrefix = annotationNamePrefix %}
{% else %}
  {% set annotationTemp = data.imageReadingTemp.annotationTemp %}
  {% set _namePrefix = "imageReadingTemp[annotationTemp]" %}
{% endif %}

{# Optional id prefix (e.g. "right" → ids become "right-abnormalityTypes") #}
{% set _idSep = "-" if (annotationIdPrefix is defined and annotationIdPrefix) else "" %}
{% set _idBase = (annotationIdPrefix + _idSep) if (annotationIdPrefix is defined and annotationIdPrefix) else "" %}

{% set abnormalityUi = "options" %} {# Set to "select" for dropdown, "options" for option picker, or "none" to hide abnormality type input #}

{% if abnormalityUi == "select" %}
  {% set abnormalityOptions = [{
    value: "",
    text: "Select type",
    disabled: true,
    selected: true if not annotationTemp.abnormalityType
  }] %}
  {% for type in data.abnormalityTypes %}
    {% set abnormalityOptions = abnormalityOptions | push({ value: type, text: type }) %}
  {% endfor %}

  {{ select({
    id: _idBase + "abnormalityType",
    name: _namePrefix + "[abnormalityType]",
    value: annotationTemp.abnormalityType,
    label: {
      text: "Abnormality type",
      classes: "nhsuk-label--s"
    },
    items: abnormalityOptions
  } | populateErrors) }}

  Conditional "other details" field — shown via JS when "Other" is selected
  <div id="{{ _idBase }}other-details-wrapper" class="{{ 'nhsuk-u-visually-hidden' if annotationTemp.abnormalityType != 'Other' }}">
    {{ input({
      id: _idBase + "otherDetails",
      name: _namePrefix + "[otherDetails]",
      value: annotationTemp.otherDetails,
      label: {
        text: "Provide details",
        classes: "nhsuk-label--s"
      },
      classes: "nhsuk-u-width-two-thirds"
    } | populateErrors) }}
  </div>
{% endif %}

{% if abnormalityUi == "options" %}
  {% set otherDetailsHtml %}
    {{ input({
      id: _idBase + "otherDetails",
      name: _namePrefix + "[otherDetails]",
      value: annotationTemp.otherDetails,
      classes: "nhsuk-u-width-two-thirds",
      label: {
        text: "Describe the abnormality"
      }
    } | populateErrors) }}
  {% endset %}

  {% set abnormalityItems = [] %}
  {% for type in data.abnormalityTypes %}
    {% if type == "Other" %}
      {% set abnormalityItems = abnormalityItems | push({ value: type, text: type, conditional: { html: otherDetailsHtml, inline: true } }) %}
    {% else %}
      {% set abnormalityItems = abnormalityItems | push({ value: type, text: type }) %}
    {% endif %}
  {% endfor %}

  {{ appOptionPicker({
    idPrefix: _idBase + "abnormalityTypes",
    name: _namePrefix + "[abnormalityTypes]",
    values: annotationTemp.abnormalityTypes,
    allowMultiple: true,
    fieldset: {
      legend: {
        text: "Abnormality type",
        size: "s"
      }
    },
    items: abnormalityItems
  } | populateErrors) }}
{% endif %}



