    { value: "2", text: "2 – Benign" },
    { value: "1", text: "1 – Normal" }
  ]
} | populateErrors) }} #}

  {{ appOptionPicker({
    id: _idBase + "levelOfConcern",
    name: _namePrefix + "[levelOfConcern]",
    value: annotationTemp.levelOfConcern,
    joined: true,
    fieldset: {
      legend: { 
        text: "Level of concern",
        size: "s"
       }
    },
    hint: {
      text: "From ‘5 - highly suspicious’ to ‘1 - normal’"
    },
    items: [
      { value: "5", text: "5" },
      { value: "4", text: "4" },
      { value: "3", text: "3" },
      { value: "2", text: "2" },
      { value: "1", text: "1" }
    ]
  } | populateErrors) }}

{% call appCollapsibleInput({ text: "Add a comment about this abnormality" }) %}
  {{ input({
    id: _idBase + "comment",
    name: _namePrefix + "[comment]",
    value: annotationTemp.comment,
    label: {
      text: "Comment (optional)",
      classes: "nhsuk-label--s"
    },
    classes: "nhsuk-u-width-two-thirds"
  }) }}
{% endcall %}
