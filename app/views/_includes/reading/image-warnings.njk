{# app/views/_includes/reading/image-warnings.njk #}
{# Displays image warnings and notes for the reader in a feature card with summary list #}

{% set imageWarningRows = [] %}

{# 1. Image quality (imperfect but best possible) #}
{% if appointment.mammogramData.isImperfectButBestPossible and appointment.mammogramData.isImperfectButBestPossible | includes("yes") %}
  {% set imageWarningRows = imageWarningRows | push({
    key: { text: "Image quality" },
    value: { text: "Imperfect, but best possible images" }
  }) %}
{% endif %}

{# 2. Additional images (repeats or extra images for large breasts) #}
{% if appointment.mammogramData.metadata.hasAdditionalImages %}
  {% if appointment.mammogramData.metadata.hasRepeat and appointment.mammogramData.metadata.hasExtraImages %}
    {% set additionalImagesText = "Some views were retaken. Extra images were also taken for large breasts." %}
  {% elseif appointment.mammogramData.metadata.hasRepeat %}
    {% set additionalImagesText = "Some views were retaken due to technical issues." %}
  {% elseif appointment.mammogramData.metadata.hasExtraImages %}
    {% set additionalImagesText = "Extra images were taken to ensure full coverage for large breasts." %}
  {% else %}
    {% set additionalImagesText = "Some views have additional images." %}
  {% endif %}
  {% set imageWarningRows = imageWarningRows | push({
    key: { text: "Additional images" },
    value: { text: additionalImagesText }
  }) %}
{% endif %}

{# 3. Incomplete mammography #}
{% if appointment.mammogramData.isIncompleteMammography and appointment.mammogramData.isIncompleteMammography | includes("yes") %}
  {% set incompleteValueHtml %}
    {% if appointment.mammogramData.incompleteMammographyReasons and appointment.mammogramData.incompleteMammographyReasons | length > 0 %}
      {% if appointment.mammogramData.incompleteMammographyReasons | length == 1 %}
        <p class="nhsuk-u-margin-bottom-2">Reason: {{ appointment.mammogramData.incompleteMammographyReasons[0] | lower }}</p>
      {% else %}
        <p class="nhsuk-u-margin-bottom-1">{{ "Reason" | pluralise(appointment.mammogramData.incompleteMammographyReasons | length) }}:</p>
        <ul class="nhsuk-list nhsuk-list--bullet nhsuk-u-margin-bottom-2">
          {% for reason in appointment.mammogramData.incompleteMammographyReasons %}
            <li>{{ reason }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    {% endif %}
    {% if appointment.mammogramData.incompleteMammographyReasonDetails %}
      <p class="nhsuk-u-margin-bottom-2">Details: {{ appointment.mammogramData.incompleteMammographyReasonDetails }}</p>
    {% endif %}
    {% if appointment.mammogramData.incompleteMammographyFollowUpAppointment %}
      {% set followUpValue = appointment.mammogramData.incompleteMammographyFollowUpAppointment %}
      {% if followUpValue.startsWith("No") %}
        {{ tag({
          text: "Partial mammography",
          colour: "orange"
        }) }}
      {% else %}
        {{ tag({
          text: "Recall requested",
          colour: "orange"
        }) }}
        {% if appointment.mammogramData.incompleteMammographyFollowUpAppointmentDetails %}
          <p class="nhsuk-u-margin-top-2 nhsuk-u-margin-bottom-0">Note for scheduling recall appointment:<br>{{ appointment.mammogramData.incompleteMammographyFollowUpAppointmentDetails }}</p>
        {% endif %}
      {% endif %}
    {% endif %}
  {% endset %}
  {% set imageWarningRows = imageWarningRows | push({
    key: { text: "Not all images taken" },
    value: { html: incompleteValueHtml }
  }) %}
{% endif %}

{# 4. Notes for reader #}
{% if appointment.mammogramData.notesForReader %}
  {% set imageWarningRows = imageWarningRows | push({
    key: { text: "Notes for reader" },
    value: { text: appointment.mammogramData.notesForReader }
  }) %}
{% endif %}

{# Render summary list if any rows #}
{% if imageWarningRows | length %}
  {{ summaryList({ rows: imageWarningRows, lastRowBorder: false }) }}
{% endif %}
