{# app/views/_includes/appointment-note-card.njk #}

{% if event | hasAppointmentNote %}
  {% call warningCallout({
    heading: "Appointment note",
    classes: "nhsuk-u-margin-bottom-4",
    actions: {
      items: [
        {
          href: (eventUrl + "/appointment-note") | urlWithReferrer(referrerChain),
          text: "Change",
          visuallyHiddenText: "note"
        } | openInModal
      ]
    } if allowEdits
  }) %}
    <div class="nhsuk-grid-row">
      <div class="nhsuk-grid-column-two-thirds">
        <p>{{ event.appointmentNote }}</p>
      </div>
    </div>
  {% endcall %}
{% endif %}