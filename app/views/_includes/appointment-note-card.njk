{# app/views/_includes/appointment-note-card.njk #}

{% set item = {
  href: (appointmentUrl + "/appointment-note") | urlWithReferrer(referrerChain),
  text: "Change",
  visuallyHiddenText: "note"
} %}

{# Awkwardly support temporarily bypssing modal from calling page
TODO: make this cleaner #}
{% if not noModals %}
  {% set item = item | openInModal %}
{% endif %}

{% if appointment | hasAppointmentNote %}
  {% call warningCallout({
    heading: "Appointment note",
    classes: "nhsuk-u-margin-bottom-4",
    actions: {
      items: [
        item
      ]
    } if allowEdits
  }) %}
    <div class="nhsuk-grid-row">
      <div class="nhsuk-grid-column-two-thirds">
        <p>{{ appointment.appointmentNote }}</p>
      </div>
    </div>
  {% endcall %}
{% endif %}