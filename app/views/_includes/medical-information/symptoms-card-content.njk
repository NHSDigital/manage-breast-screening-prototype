
{% set scrollTo = sectionId %}

{% set symptomsCount = event.medicalInformation.symptoms and event.medicalInformation.symptoms | length %}
{% set hasSymptoms = symptomsCount > 0 %}

{% set symptomsContentsSummaryText %}
  {{ symptomsCount or "No" }} {{ 'symptom' | pluralise(symptomsCount) }} recorded
{% endset %}


{% include "summary-lists/medical-information/symptoms/summary.njk" %}

{% if not hasSymptoms %}
  {% set insetHtml %}
    <p>No symptoms have been recorded for this participant.</p>
  {% endset %}
  {{ insetText({
    html: insetHtml
  }) }}
{% endif %}

{% set linkHref %}
  {{ contextUrl + "/medical-information/symptoms/add" | urlWithReferrer(currentUrl, scrollTo) }}
{% endset %}

{# <p class="nhsuk-u-margin-top-4 nhsuk-u-margin-bottom-0">
  <a href="{{ linkHref }}" class="nhsuk-link">{{ "Add another symptom" if hasSymptoms else "Add a symptom" }}</a>
</p> #}

{% if allowEdits %}
  <h4>Add symptoms</h4>

  <div class="nhsuk-button-group app-button-group--small">
    {% for symptomType in data.symptomTypes %}

      {% set addUrl = (contextUrl + "/medical-information/symptoms/add?symptomType=" + symptomType.slug) | urlWithReferrer(referrerChain | appendReferrer(currentUrl), scrollTo) %}

      {% if data.settings.screening.modalForms == 'true' %}
        {# Modal mode: button triggers a modal that fetches the form as a fragment #}
        {% set modalId = "symptom-modal-" + sectionId %}
        {{ button({
          text: symptomType.name | sentenceCase,
          classes: "nhsuk-button--secondary nhsuk-button--small",
          attributes: {
            type: "button",
            onclick: "openModal('" + modalId + "', { loadUrl: '" + addUrl + "' }); return false;"
          }
        }) }}
      {% else %}
        {# Standard mode: button navigates to the add symptom page #}
        {{ button({
          text: symptomType.name | sentenceCase,
          href: addUrl,
          classes: "nhsuk-button--secondary nhsuk-button--small"
        }) }}
      {% endif %}

    {% endfor %}
  </div>

  {# Single shared modal shell — only rendered when modal forms are enabled.
     Content is loaded at open time via the loadUrl option. #}
  {% if data.settings.screening.modalForms == 'true' %}
    {% from '_components/modal/macro.njk' import appModal %}
    {{ appModal({ id: "symptom-modal-" + sectionId }) }}
  {% endif %}

{% endif %}
