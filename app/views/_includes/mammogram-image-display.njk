{# app/views/_includes/mammogram-image-display.njk #}
{#
  Display a single mammogram view with count/images

  Parameters:
  - viewItem: object with { side, viewShort, viewShortWithSide, count, images, isMissing, repeatCount, repeatReasons, etc }
  - mammogramImages: object from getImagesForEvent (needed for automated entry)
  - isManualEntry: boolean - true shows count only, false shows image thumbnails
  - hideAdditionalDetails: boolean - suppress repeat/extra image details
#}

<div class="app-mammogram-view--{{ viewItem.side }}">

  {% if isManualEntry %}
    {# Manual entry - show count only #}
    <h3 class="nhsuk-u-margin-bottom-2">
      {{ viewItem.count }}× {{ viewItem.viewShortWithSide }}
    </h3>

    {# Show repeat information if present #}
    {% if viewItem.repeatCount > 0 and viewItem.repeatReasons %}
      <p class="nhsuk-u-margin-bottom-0">
        <strong>Repeat {{ 'reason' | pluralise(viewItem.repeatReasons | length) }}:</strong> {{ viewItem.repeatReasons | join(', ') }}
      </p>
    {% endif %}

  {% else %}
    {# Automated entry - show image thumbnails #}
    {% set viewKey = viewItem.viewShortWithSide | lower %}
    {% set allPaths = mammogramImages.allPaths[viewKey] if (mammogramImages and mammogramImages.allPaths) else null %}

    {% if viewItem.isMissing or not allPaths %}
      {# Missing view placeholder #}
      {# <h3 class="nhsuk-u-margin-bottom-2 nhsuk-u-secondary-text-color">
        0× {{ viewItem.viewShortWithSide }}
      </h3> #}

      <div class="app-mammogram-thumbnail app-mammogram-thumbnail--{{ viewItem.side }}">
        <div class="app-mammogram-thumbnail__image-wrapper{{ ' app-mammogram-thumbnail__image-wrapper--' + thumbnailSize if thumbnailSize }}">
          <span class="app-mammogram-thumbnail__label">{{ viewItem.viewShortWithSide }}</span>
          <div class="app-mammogram-thumbnail__missing">
            <span class="app-mammogram-thumbnail__missing-text">No image</span>
          </div>
        </div>
      </div>

    {% else %}
      {# Present view with images #}
      {% set imageCount = 1 if allPaths is string else allPaths | length %}

      {# <h3 class="nhsuk-u-margin-bottom-2">
        {{ imageCount }}× {{ viewItem.viewShortWithSide }}
      </h3> #}

      <div class="app-mammogram-thumbnail app-mammogram-thumbnail--{{ viewItem.side }}">
        {% if allPaths is string %}
          <div class="app-mammogram-thumbnail__image-wrapper{{ ' app-mammogram-thumbnail__image-wrapper--' + thumbnailSize if thumbnailSize }}">
            <span class="app-mammogram-thumbnail__label">{{ viewItem.viewShortWithSide }}</span>
            <img class="app-mammogram-thumbnail__image" src="{{ allPaths }}" alt="{{ viewItem.viewShortWithSide }} view">
          </div>
        {% else %}
          {% for imagePath in allPaths %}
            <div class="app-mammogram-thumbnail__image-wrapper{{ ' app-mammogram-thumbnail__image-wrapper--' + thumbnailSize if thumbnailSize }}">
              <span class="app-mammogram-thumbnail__label">{{ viewItem.viewShortWithSide }}</span>
              <img class="app-mammogram-thumbnail__image" src="{{ imagePath }}" alt="{{ viewItem.viewShortWithSide }} view ({{ loop.index }} of {{ loop.length }})">
            </div>
          {% endfor %}
        {% endif %}
      </div>

      {# Additional image details (repeats and extras) #}
      {% if not hideAdditionalDetails and (viewItem.repeatCount > 0 or imageCount > 1) %}
        {% set repeatCount = viewItem.repeatCount or 0 %}
        {% set extraCount = (imageCount - 1) - repeatCount %}
        
        {% set additionalDetailsHtml %}
          {# Show repeat information #}
          {% if repeatCount > 0 %}
            <p class="nhsuk-u-margin-bottom-2">
              {{ repeatCount }} {{ 'repeat' | pluralise(repeatCount) }} taken
            </p>
            {% if viewItem.repeatReasons and viewItem.repeatReasons | length > 0 %}
              {% if viewItem.repeatReasons | length == 1 %}
                <p class="nhsuk-u-margin-bottom-2">
                  {{ viewItem.repeatReasons[0] }}
                </p>
              {% else %}
                <p class="nhsuk-u-margin-bottom-2"><strong>Repeat reasons:</strong></p>
                <ul class="nhsuk-list nhsuk-list--bullet nhsuk-u-margin-bottom-2">
                  {% for reason in viewItem.repeatReasons %}
                    <li>{{ reason }}</li>
                  {% endfor %}
                </ul>
              {% endif %}
            {% endif %}
          {% endif %}
          
          {# Show extra image information #}
          {% if extraCount > 0 %}
            <p class="nhsuk-u-margin-bottom-0">
              {% if extraCount == 1 %}
                An extra image was taken to capture the complete view.
              {% else %}
                {{ extraCount }} extra images were taken to capture the complete view.
              {% endif %}
            </p>
          {% endif %}
        {% endset %}
        
        <div class="nhsuk-u-margin-top-3">
          {{ details({
            summaryText: "Additional image details",
            html: additionalDetailsHtml
          }) }}
        </div>
      {% endif %}
    {% endif %}

  {% endif %}

</div>
