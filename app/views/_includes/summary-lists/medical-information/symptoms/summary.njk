{# /app/views/_includes/summary-lists/appointment-symptoms.njk #}

{% set hasSymptoms = appointment | hasSymptoms %}

{% if hasSymptoms %}
  {% set rows = [] %}

  {% for symptom in appointment.medicalInformation.symptoms %}

    {# Build the key (left column) - just the symptom type #}
    {# {% set keyText = symptom.type or "" %} #}

    {% set keyText %}
      {{ symptom.type | sentenceCase }}
      {% if symptom.isSignificant and not isReadingWorkflow %}
        <br>{{ "Highlight to image readers" | toTag }}
      {% endif %}
    {% endset %}

    {# Build the value (right column) - all supporting details #}
    {% set valueLines = [] %}

    {# Sign noted by the mammographer rather than reported by the participant #}
    {% if symptom.isMammographerObserved %}
      {% set notedByName = (symptom.addedByUserId | getUsername({ format: "short", useYou: true })) or "mammographer" %}
      {% set valueLines = valueLines | push("Sign noted by " + notedByName) %}
    {% endif %}

    {# Add sub-type as first line with appropriate descriptor #}
    {% if symptom.type == "Nipple change" and symptom.nippleChangeType %}
      {% if symptom.nippleChangeType == "other" and symptom.nippleChangeDescription %}
        {% set valueLines = valueLines | push("Change type: " + (symptom.nippleChangeDescription)) %}
      {% else %}
        {% set valueLines = valueLines | push("Change type: " + (symptom.nippleChangeType)) %}
      {% endif %}
    {% elseif symptom.type == "Skin change" and symptom.skinChangeType %}
      {% if symptom.skinChangeType == "other" and symptom.skinChangeDescription %}
        {% set valueLines = valueLines | push("Change type: " + (symptom.skinChangeDescription)) %}
      {% else %}
        {% set valueLines = valueLines | push("Change type: " + (symptom.skinChangeType)) %}
      {% endif %}
    {% elseif symptom.type == "Other" and symptom.otherDescription %}
      {% set valueLines = valueLines | push("Description: " + (symptom.otherDescription)) %}
    {% endif %}

    {# Location information #}
    {% if symptom.type == "Nipple change" and symptom.nippleChangeLocation %}
      {% if symptom.nippleChangeLocation | length > 1 %}
        {% set valueLines = valueLines | push("Both nipples") %}
      {% else %}
        {% set valueLines = valueLines | push(symptom.nippleChangeLocation[0] | sentenceCase) %}
      {% endif %}
    {% elseif symptom.location %}
      {# Handle location as array (right breast, left breast, other); support legacy string values #}
      {% set locArray = [symptom.location] if symptom.location is string else symptom.location %}
      {% set hasRight = "right breast" in locArray %}
      {% set hasLeft = "left breast" in locArray %}
      {% set hasOther = "other" in locArray %}

      {% if hasRight and hasLeft %}
        {% if symptom.rightBreastDescription and symptom.leftBreastDescription %}
          {% set locationText = "Both breasts (right: " + symptom.rightBreastDescription + ", left: " + symptom.leftBreastDescription + ")" %}
        {% elseif symptom.rightBreastDescription %}
          {% set locationText = "Both breasts (right: " + symptom.rightBreastDescription + ")" %}
        {% elseif symptom.leftBreastDescription %}
          {% set locationText = "Both breasts (left: " + symptom.leftBreastDescription + ")" %}
        {% else %}
          {% set locationText = "Both breasts" %}
        {% endif %}
      {% elseif hasRight %}
        {% if symptom.rightBreastDescription %}
          {% set locationText = "Right breast: " + symptom.rightBreastDescription %}
        {% else %}
          {% set locationText = "Right breast" %}
        {% endif %}
      {% elseif hasLeft %}
        {% if symptom.leftBreastDescription %}
          {% set locationText = "Left breast: " + symptom.leftBreastDescription %}
        {% else %}
          {% set locationText = "Left breast" %}
        {% endif %}
      {% else %}
        {% set locationText = "" %}
      {% endif %}

      {% if hasOther %}
        {% if symptom.otherLocationDescription %}
          {% set otherText = "Other: " + symptom.otherLocationDescription %}
        {% else %}
          {% set otherText = "Other location" %}
        {% endif %}
        {% if locationText %}
          {% set locationText = locationText + ", " + otherText %}
        {% else %}
          {% set locationText = otherText %}
        {% endif %}
      {% endif %}

      {% if locationText %}
        {% set valueLines = valueLines | push(locationText) %}
      {% endif %}
    {% endif %}

    {# Start date #}
    {% set startText %}
      Started:
      {% if symptom.dateType == 'dateKnown' and symptom.dateStarted %}
        {{ symptom.dateStarted | formatMonthYear }} ({{ symptom.dateStarted | formatRelativeDate }})
      {% elseif symptom.approximateDuration %}
        {{ symptom.approximateDuration }} ago
      {% elseif symptom.dateType == 'notKnown' %}
        not known
      {% else %}
        not provided
      {% endif %}
    {% endset %}
    {% set valueLines = valueLines | push(startText) %}

    {# Additional symptom information #}
    {% if symptom.isIntermittent %}
      {% set valueLines = valueLines | push("Symptom is intermittent") %}
    {% endif %}

    {% if symptom.hasStopped and symptom.approximateDateStopped %}
      {% set valueLines = valueLines | push("Recently resolved (" + symptom.approximateDateStopped + ")") %}
    {% endif %}

    {# Investigation status #}
    {% if symptom.hasBeenInvestigated == "yes" %}
      {% if symptom.investigatedDescription %}
        {% set valueLines = valueLines | push("Previously investigated: " + symptom.investigatedDescription) %}
      {% else %}
        {% set valueLines = valueLines | push("Previously investigated") %}
      {% endif %}
    {% endif %}

    {# Symptom notes #}
    {% if symptom.symptomNotes %}
      {% set valueLines = valueLines | push("Notes: " + symptom.symptomNotes) %}
    {% endif %}

    {# Join all value lines with line breaks #}
    {% set symptomValueHtml = valueLines | join('<br>') %}

    {# Build the Change action #}
    {% set editUrl = contextUrl + "/medical-information/symptoms/edit/" + symptom.id %}
    {% set changeItem = {
      href: editUrl | urlWithReferrer(referrerChain | appendReferrer(currentUrl)),
      text: "Change",
      visuallyHiddenText: symptom.type | lower
    } %}

    {% set rows = rows | push({
      key: {
        html: keyText
      },
      value: {
        html: symptomValueHtml
      },
      actions: {
        items: [changeItem]
      } if allowEdits,
      classes: "nhsuk-summary-list__row--no-border" if loop.last
    }) %}
  {% endfor %}

  {{ summaryList({
    rows: rows
  } | openInModal) }}
{% endif %}
