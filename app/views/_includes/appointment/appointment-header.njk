{# app/views/_includes/appointment-header.njk #}

{# Banner if appointment is paused #}
{% if appointment | isPaused %}
  {% set pausedBannerHtml %}
    <p class="nhsuk-notification-banner__heading">
      This appointment is paused.
    </p>
  {% endset %}

  {{ notificationBanner({
    html: pausedBannerHtml,
    type: "information"
  }) }}
{% endif %}

{# Banner if appointment is in progress (not paused) by someone else #}
{% if (appointment | isInProgressNotPaused) and not appointment | startedByCurrentUser %}
  {% set notificationBannerHtml %}
    <p class="nhsuk-notification-banner__heading">
      This appointment is currently being run by {{ appointment.sessionDetails.startedBy | getUsername({
        format: 'short',
        identifyCurrentUser: true
      }) }}.
    </p>
  {% endset %}

  {{ notificationBanner({
    html: notificationBannerHtml,
    type: "information"
  }) }}
{% endif %}

<div class="app-header-with-status">
  <h1 class="nhsuk-heading-l">
    <span class="nhsuk-caption-l">
      {{ clinic.clinicType | sentenceCase }} appointment
    </span>
    {{ participant | getFullName | safe }}
  </h1>

  <div class="app-header-with-status__status-tag">
    {% set statusTagId = "status-tag-" + appointment.id %}
    {{ appointment.status | toTag({
      vocabulary: 'appointment',
      id: statusTagId,
      classes: "nhsuk-u-margin-bottom-2"
    }) }}

    {% if appointment.status == 'scheduled' %}
      {{ appCheckIn({
        clinicId: clinicId,
        appointment: appointment,
        participant: participant,
        confirmIdentityOnCheckIn: true if data.settings.screening.confirmIdentityOnCheckIn == 'true' else false,
        statusTagId: statusTagId
      }) }}
    {% endif %}

    <br>

    {% if allowEdits %}
      <ul class="nhsuk-list">
        <li>
          {{ appLink({
            text: "Cancel or reschedule appointment",
            href: (appointmentUrl + '/cancel-or-reschedule-appointment/details') | urlWithReferrer(appointmentUrl)
          } | openInModal) }}
        </li>
        <li>
          {{ appLink({
            text: "Make special appointment" if not appointment | isSpecialAppointment else "Change special appointment details",
            href: (appointmentUrl + '/special-appointment/edit') | urlWithReferrer(appointmentUrl)
          } | openInModal) }}
        </li>
      </ul>
    {% endif %}

    {# 
    {{ buttonMenu({
      items: [
        {
          text: "Reschedule appointment",
          href: "#" | urlWithReferrer(currentUrl),
          variant: "secondary"
        },
        {
          text: "Cancel appointment",
          href: "#" | urlWithReferrer(currentUrl),
          variant: "secondary"
        },
        {
          text: "Make this appointment a special appointment" if not appointment | isSpecialAppointment else "Change special appointment details",
          href: appointmentUrl ~ "/special-appointment/edit" | urlWithReferrer(appointmentUrl),
          variant: "secondary"
        }
      ],
      button: {
        text: "Appointment actions",
        variant: "secondary"
      },
      alignMenu: "right"
    }) }}
    #}
  </div>
</div>

<p class="nhsuk-u-secondary-text-colour">
  <span>NHS Number: {{ participant.medicalInformation.nhsNumber | formatNhsNumber }}</span>
</p>

<p>
  {{ appointment.timing.startTime | formatTimeString }} ({{ appointment.timing.duration }} minutes) - {{ clinic.date | formatDate }} ({{ clinic.date | formatRelativeDate }})
</p>

{# Suppressed until we decide whether to ship the participant record #}
{% if data.settings.screening.showParticipantSection | falsify %}
  <p class="nhsuk-u-margin-bottom-4"><a href="{{ '/participants/' + participant.id | urlWithReferrer(currentUrl) }}">View participant record</a></p>
{% endif %}

{% if currentUser | isClinician %}
  {% if appointment | isPaused or (appointment | isInProgress and appointment | startedByCurrentUser) %}
    <div class="nhsuk-button-group">
      {{ button({
        text: "Resume appointment",
        href: "./resume"
      }) }}
      <a href="{{ (appointmentUrl + '/attended-not-screened-reason') | urlWithReferrer(currentUrl) }}" class="nhsuk-link app-link--warning">
        Appointment cannot proceed
      </a>
    </div>
  {% elseif appointment | hasNotStarted %}
    <div class="nhsuk-button-group">
      {{ button({
        text: "Start this appointment",
        href: "./start"
      }) }}
    </div>
  {% endif %}
{% endif %}

{% include "_includes/appointment/appointment-tabs.njk" %}